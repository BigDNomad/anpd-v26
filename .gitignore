__pycache__/

# Generated work artifacts (synopsis assemblies, audit reports, state files, logs)
series/*/b*/work/synopsis*.md
series/*/b*/work/synopsis_chapters/
series/*/b*/work/synopsis_audit_report.*
series/*/b*/work/synopsis_findings.json
series/*/b*/work/synopsis_generation_state.json
series/*/b*/work/synopsis_generator_receipt.json
series/*/b*/work/*.log

# Run output products
series/*/b*/out/manifest_audits/
series/*/b*/out/reports/*.json
series/*/b*/out/reports/*.md
series/*/b*/out/scenes/*
!series/*/b*/out/scenes/*.md
series/*/b*/out/state/

# Run output files (manuscripts, exports, logs)
series/*/b*/out/*.md
series/*/b*/out/*.docx
series/*/b*/out/chapters/
series/*/b*/out/reports/*.log
series/*/b*/out/_archive/

# Work-dir runtime artifacts (character profiles, backups, bundles, gate stdout)
series/*/b*/work/character_profiles_*.json
series/*/b*/work/character_generation_findings.json
series/*/b*/work/gate3_stdout_*.json
series/*/b*/work/scenes_backup_*/
series/*/b*/work/bundles/
series/*/b*/work/archive_*/

# Cert attempt archives
series/*/b*cert/attempt*_archive/

# Repo-root run products
/out/

# Summarizer failure dumps (should go to work/ not repo root)
summarizer_failure_*.txt
